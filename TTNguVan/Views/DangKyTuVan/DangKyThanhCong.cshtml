@{
    Layout = null;
    ViewData["Title"] = "Đăng ký thành công";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Đăng ký thành công - Ngữ Văn Minh Anh</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap">

    <style>
        * {
            font-family: 'Inter', sans-serif !important;
        }
        body {
            margin: 0;
            background: linear-gradient(135deg, #E8F7F4, #F8FCFB);
            color: #1f2937;
        }

        .page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }

        .card {
            width: 100%;
            max-width: 520px;
            background: white;
            border-radius: 26px;
            box-shadow: 0 18px 50px rgba(15, 23, 42, 0.16);
            padding: 38px;
            text-align: center;
            border: 1px solid #D7EEE9;
        }

        .icon {
            width: 78px;
            height: 78px;
            border-radius: 50%;
            background: #DDF4EF;
            color: #2F9C8A;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 18px;
            font-size: 40px;
            font-weight: 900;
        }

        h1 {
            margin: 0;
            font-size: 27px;
            color: #0f172a;
        }

        p {
            color: #64748b;
            line-height: 1.6;
            font-size: 15px;
        }

        .btn {
            display: inline-block;
            margin-top: 16px;
            text-decoration: none;
            background: linear-gradient(135deg, #4DB6A3, #2F9C8A);
            color: white;
            padding: 13px 22px;
            border-radius: 14px;
            font-weight: 800;
        }
    </style>
</head>

<body>
    <div class="page">
        <div class="card">
            <div class="icon">✓</div>

            <h1>Đăng ký thành công</h1>

            <p>
                Cảm ơn anh/chị đã để lại thông tin.
                Trung tâm Ngữ Văn Minh Anh sẽ liên hệ tư vấn trong thời gian sớm nhất.
            </p>

            <a class="btn" href="/DangKyTuVan">
                Gửi đăng ký khác
            </a>
        </div>
    </div>
</body>
</html>