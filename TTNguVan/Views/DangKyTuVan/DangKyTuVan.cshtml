@model TTNguVan.Controllers.DangKyTuVanViewModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng ký tư vấn";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Đăng ký tư vấn - Ngữ Văn Minh Anh</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap">

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: 'Lexend', sans-serif;
            background: linear-gradient(135deg, #edf7f5 0%, #f7fbfa 100%);
            color: #1f2937;
        }

        .register-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 16px;
        }

        .register-card {
            width: 100%;
            max-width: 540px;
            background: #ffffff;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 20px 50px rgba(20, 82, 73, 0.12);
            border: 1px solid rgba(79, 186, 164, 0.16);
        }

        .register-header {
            background: linear-gradient(135deg, #54c3b0 0%, #2fa392 100%);
            color: white;
            text-align: center;
            padding: 28px 24px 24px;
        }

        .register-logo {
            width: 64px;
            height: 64px;
            margin: 0 auto 14px;
            border-radius: 18px;
            background: rgba(255, 255, 255, 0.18);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            backdrop-filter: blur(8px);
        }

        .register-title {
            margin: 0;
            font-size: 24px;
            font-weight: 700;
            letter-spacing: -0.3px;
        }

        .register-subtitle {
            margin-top: 8px;
            font-size: 15px;
            font-weight: 400;
            opacity: 0.96;
        }

        .register-body {
            padding: 28px 28px 24px;
        }

        .form-group {
            margin-bottom: 18px;
        }

        .form-label {
            display: block;
            margin-bottom: 8px;
            font-size: 15px;
            font-weight: 600;
            color: #1f2937;
        }

        .required {
            color: #ef4444;
            margin-left: 3px;
        }

        .form-control,
        .form-select,
        textarea.form-control {
            width: 100%;
            border: 1.5px solid #d7ebe7;
            background: #fcfefe;
            border-radius: 16px;
            padding: 14px 16px;
            font-size: 15px;
            font-family: 'Lexend', sans-serif;
            color: #1f2937;
            outline: none;
            transition: all 0.2s ease;
        }

            .form-control::placeholder,
            textarea.form-control::placeholder {
                color: #94a3b8;
            }

            .form-control:focus,
            .form-select:focus,
            textarea.form-control:focus {
                border-color: #42b8a4;
                box-shadow: 0 0 0 4px rgba(66, 184, 164, 0.14);
                background: #ffffff;
            }

        textarea.form-control {
            min-height: 96px;
            resize: vertical;
        }

        .submit-btn {
            width: 100%;
            border: none;
            border-radius: 18px;
            background: linear-gradient(135deg, #54c3b0 0%, #2fa392 100%);
            color: white;
            font-family: 'Lexend', sans-serif;
            font-size: 18px;
            font-weight: 600;
            padding: 15px 20px;
            cursor: pointer;
            box-shadow: 0 10px 24px rgba(47, 163, 146, 0.24);
            transition: all 0.2s ease;
        }

            .submit-btn:hover {
                transform: translateY(-1px);
                box-shadow: 0 14px 28px rgba(47, 163, 146, 0.28);
            }

            .submit-btn:active {
                transform: translateY(0);
            }

        .register-note {
            margin-top: 16px;
            text-align: center;
            font-size: 13px;
            color: #64748b;
            line-height: 1.6;
        }

        .validation-summary-errors,
        .text-danger {
            color: #dc2626;
            font-size: 13px;
            margin-top: 6px;
        }

        @@media (max-width: 576px) {
            .register-body {
                padding: 22px 18px 20px;
            }

            .register-title {
                font-size: 22px;
            }

            .register-subtitle {
                font-size: 14px;
            }
        }
    </style>
</head>

<body>
    <div class="register-page">
        <div class="register-card">
            <div class="register-header">
                <h1 class="register-title">Ngữ Văn Minh Anh</h1>
                <div class="register-subtitle">Đăng ký nhận tư vấn khóa học</div>
            </div>

            <div class="register-body">
                <form asp-controller="DangKyTuVan" asp-action="Index" method="post">
                    <div class="form-group">
                        <label asp-for="HoTen" class="form-label">
                            Họ tên phụ huynh / học sinh <span class="required">*</span>
                        </label>
                        <input asp-for="HoTen" class="form-control" placeholder="Ví dụ: Nguyễn Thị Thu Hà" />
                        <span asp-validation-for="HoTen" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="SoDienThoai" class="form-label">
                            Số điện thoại liên hệ <span class="required">*</span>
                        </label>
                        <input asp-for="SoDienThoai" class="form-control" maxlength="10" placeholder="Ví dụ: 0983112233" />
                        <span asp-validation-for="SoDienThoai" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="KhoiLop" class="form-label">
                            Khối lớp quan tâm <span class="required">*</span>
                        </label>
                        <select asp-for="KhoiLop" class="form-select">
                            <option value="6">Lớp 6</option>
                            <option value="7">Lớp 7</option>
                            <option value="8">Lớp 8</option>
                            <option value="9">Lớp 9</option>
                            <option value="10">Lớp 10</option>
                            <option value="11">Lớp 11</option>
                            <option value="12">Lớp 12</option>
                        </select>
                        <span asp-validation-for="KhoiLop" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="NguonDen" class="form-label">
                            Nguồn tiếp nhận <span class="required">*</span>
                        </label>
                        <select asp-for="NguonDen" class="form-select">
                            <option value="Website">Website</option>
                            <option value="Facebook">Facebook</option>
                            <option value="Hotline">Hotline</option>
                            <option value="Giới thiệu">Giới thiệu</option>
                            <option value="Khác">Khác</option>
                        </select>
                        <span asp-validation-for="NguonDen" class="text-danger"></span>
                    </div>

                    <button type="submit" class="submit-btn">
                        Gửi đăng ký tư vấn
                    </button>

                    <div class="register-note">
                        Sau khi gửi thông tin, trung tâm sẽ liên hệ lại trong thời gian sớm nhất.
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>