@model TTNguVan.Controllers.DangKyTuVanViewModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng ký tư vấn";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Đăng ký tư vấn - Ngữ Văn Minh Anh</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background-color: #f6f8f9; 
            color: #1f2937;
        }

        .page-container {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 40px 16px;
        }

        .header-section {
            text-align: center;
            margin-bottom: 24px;
        }

        .brand-icon {
            background-color: #52b7a4;
            color: white;
            width: 52px;
            height: 52px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 26px;
            margin: 0 auto 16px;
        }

        .header-title {
            margin: 0 0 8px;
            font-size: 24px;
            font-weight: 700;
            color: #111827;
        }

        .header-subtitle {
            margin: 0;
            font-size: 14px;
            color: #6b7280;
        }

        .form-card {
            background: #ffffff;
            width: 100%;
            max-width: 420px; 
            border-radius: 12px;
            padding: 32px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            margin-bottom: 8px;
            font-size: 13px;
            font-weight: 600;
            color: #374151;
        }

        .required {
            color: #ef4444;
        }

        /* BỌC INPUT ĐỂ CHỨA ICON */
        .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-icon {
            position: absolute;
            left: 14px;
            color: #9ca3af;
            font-size: 14px;
        }

        .form-control,
        .form-select {
            width: 100%;
            border: 1px solid #e5e7eb;
            background: #ffffff;
            border-radius: 8px;
            padding: 12px 14px 12px 40px; 
            font-size: 14px;
            font-family: 'Inter', sans-serif;
            color: #1f2937;
            outline: none;
            transition: all 0.2s ease;
        }

        .form-select {
            appearance: none;
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23343a40' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M2 5l6 6 6-6'/%3e%3c/svg%3e");
            background-repeat: no-repeat;
            background-position: right 14px center;
            background-size: 12px 12px;
        }

        .form-control::placeholder {
            color: #9ca3af;
        }

        .form-control:focus,
        .form-select:focus {
            border-color: #52b7a4;
            box-shadow: 0 0 0 3px rgba(82, 183, 164, 0.15);
        }

        .submit-btn {
            width: 100%;
            border: none;
            border-radius: 8px;
            background-color: #52b7a4;
            color: white;
            font-family: 'Inter', sans-serif;
            font-size: 15px;
            font-weight: 600;
            padding: 14px;
            cursor: pointer;
            transition: background-color 0.2s;
            margin-top: 8px;
        }

            .submit-btn:hover {
                background-color: #429f8e;
            }

        .validation-summary-errors,
        .text-danger {
            color: #dc2626;
            font-size: 12px;
            margin-top: 6px;
            display: block;
        }
    </style>
</head>

<body>
    <div class="page-container">

        <div class="header-section">
            <div class="brand-icon">
                <i class="fas fa-graduation-cap"></i>
            </div>
            <h1 class="header-title">Đăng ký tư vấn</h1>
            <p class="header-subtitle">Điền thông tin để trung tâm hỗ trợ bạn sớm nhất</p>
        </div>

        <div class="form-card">
            <form asp-controller="DangKyTuVan" asp-action="Index" method="post">

                <div class="form-group">
                    <label asp-for="HoTen" class="form-label">
                        Họ tên học sinh <span class="required">*</span>
                    </label>
                    <div class="input-wrapper">
                        <i class="input-icon far fa-user"></i>
                        <input asp-for="HoTen" class="form-control" placeholder="Nhập họ và tên..." />
                    </div>
                    <span asp-validation-for="HoTen" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="SoDienThoai" class="form-label">
                        Số điện thoại <span class="required">*</span>
                    </label>
                    <div class="input-wrapper">
                        <i class="input-icon fas fa-phone-alt"></i>
                        <input asp-for="SoDienThoai" class="form-control" maxlength="10" placeholder="0123456789" />
                    </div>
                    <span asp-validation-for="SoDienThoai" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="KhoiLop" class="form-label">
                        Khối lớp <span class="required">*</span>
                    </label>
                    <div class="input-wrapper">
                        <i class="input-icon fas fa-book-open"></i>
                        <select asp-for="KhoiLop" class="form-select">
                            <option value="6">Lớp 6</option>
                            <option value="7">Lớp 7</option>
                            <option value="8">Lớp 8</option>
                            <option value="9">Lớp 9</option>
                            <option value="10">Lớp 10</option>
                            <option value="11">Lớp 11</option>
                            <option value="12">Lớp 12</option>
                        </select>
                    </div>
                    <span asp-validation-for="KhoiLop" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="NguonDen" class="form-label">
                        Bạn biết đến trung tâm qua đâu? <span class="required">*</span>
                    </label>
                    <div class="input-wrapper">
                        <i class="input-icon fas fa-map-marker-alt"></i>
                        <select asp-for="NguonDen" class="form-select">
                            <option value="Website">Website</option>
                            <option value="Facebook">Facebook</option>
                            <option value="Hotline">Hotline</option>
                            <option value="Giới thiệu">Người quen giới thiệu</option>
                            <option value="Khác">Kênh khác</option>
                        </select>
                    </div>
                    <span asp-validation-for="NguonDen" class="text-danger"></span>
                </div>

                <button type="submit" class="submit-btn">
                    Gửi đăng ký
                </button>
            </form>
        </div>

    </div>
</body>
</html>