@model IEnumerable<TTNguVan.Models.HocVien>
@{
    ViewData["Title"] = "Lịch dạy";
    Layout = "~/Views/Shared/_TeacherLayout.cshtml";

    int thang = ViewBag.Thang;
    int nam = ViewBag.Nam;

    DateTime dauThang = new DateTime(nam, thang, 1);
    int ngayTrongThang = DateTime.DaysInMonth(nam, thang);
    int thuDauThang = ((int)dauThang.DayOfWeek == 0) ? 7 : (int)dauThang.DayOfWeek;

    var lichDay = ViewBag.LichDay as List<TTNguVan.Models.LichHoc>;
    var loiNhacs = ViewBag.LoiNhacs as List<TTNguVan.Models.LoiNhac>;
    var canhBaos = ViewBag.CanhBaos as List<TTNguVan.Models.CanhBao>;
}

@section Styles {
    <style>
        .calendar-container {
            background: #ffffff;
            border-radius: 16px;
            padding: 24px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.03);
            border: 1px solid #f1f5f9;
        }

        .calendar-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
        }

        .calendar-title {
            font-size: 22px;
            font-weight: 800;
            color: #0f172a;
            margin: 0;
        }

        .nav-form {
            display: flex;
            gap: 12px;
        }

        .nav-select {
            padding: 8px 16px;
            border-radius: 8px;
            border: 1px solid #e2e8f0;
            background: #f8fafc;
            font-weight: 600;
            color: #334155;
            outline: none;
            cursor: pointer;
        }

        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, minmax(0, 1fr));
            border-top: 1px solid #e2e8f0;
            border-left: 1px solid #e2e8f0;
            border-radius: 8px;
            overflow: hidden;
            width: 100%; 
            table-layout: fixed; 
        }

        .weekday {
            text-align: center;
            font-weight: 700;
            color: #64748b;
            font-size: 12px;
            text-transform: uppercase;
            padding: 12px 0;
            border-right: 1px solid #e2e8f0;
            border-bottom: 1px solid #e2e8f0;
            background: #f8fafc;
        }

        .day-cell {
            min-height: 140px;
            padding: 8px;
            border-right: 1px solid #e2e8f0;
            border-bottom: 1px solid #e2e8f0;
            background: #fff;
            transition: background 0.2s;
            display: flex;
            flex-direction: column;
            gap: 6px;
            height: auto;
            overflow-x: hidden; 
        }

            .day-cell:hover {
                background: #fbfcfd;
            }

            .day-cell.empty {
                background: #f8fafc;
                color: transparent;
                pointer-events: none;
            }

            .day-cell.today {
                background: #f0fdf4;
            }

        .day-num {
            font-size: 14px;
            font-weight: 600;
            color: #475569;
            margin-bottom: 4px;
            display: inline-block;
        }

        .today .day-num {
            color: #fff;
            background: #22c55e;
            border-radius: 50%;
            width: 24px;
            height: 24px;
            text-align: center;
            line-height: 24px;
        }

        .event-badge {
            padding: 6px 10px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
            line-height: 1.4;
            cursor: pointer;
            transition: transform 0.2s;
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

            .event-badge:hover {
                transform: scale(1.02);
                z-index: 10;
                position: relative;
            }

        .event-title {
            font-weight: 700;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .event-desc {
            font-weight: 500;
            font-size: 10px;
            opacity: 0.8;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .badge-schedule {
            background: #fef3c7;
            color: #b45309;
            border: 1px solid #fde68a;
        }

        .badge-reminder {
            background: #e0f2fe;
            color: #0369a1;
            border: 1px solid #bae6fd;
        }

        .badge-alert {
            background: #fee2e2;
            color: #b91c1c;
            border: 1px solid #fecaca;
        }
    </style>
}

<div class="calendar-container">
    <div class="calendar-header">
        <h2 class="calendar-title">
            <i class="far fa-calendar-alt text-primary me-2"></i>Tháng @thang, @nam
        </h2>
        <form method="get" action="/GiaoVien/LichDay" class="nav-form shadow-none m-0 p-0 border-0">
            <select name="thang" class="nav-select" onchange="this.form.submit()">
                @for (int i = 1; i <= 12; i++)
                {
                    <option value="@i" selected="@(thang == i)">Tháng @i</option>
                }
            </select>
            <select name="nam" class="nav-select" onchange="this.form.submit()">
                @for (int i = 2025; i <= 2027; i++)
                {
                    <option value="@i" selected="@(nam == i)">Năm @i</option>
                }
            </select>
        </form>
    </div>

    <div class="calendar-grid">
        <div class="weekday">Mon</div><div class="weekday">Tue</div><div class="weekday">Wed</div>
        <div class="weekday">Thu</div><div class="weekday">Fri</div><div class="weekday">Sat</div><div class="weekday">Sun</div>

        @for (int i = 1; i < thuDauThang; i++)
        {
            <div class="day-cell empty"></div>
        }

        @for (int d = 1; d <= ngayTrongThang; d++)
        {
            DateTime ngayHienTai = new DateTime(nam, thang, d);
            int thu = ((int)ngayHienTai.DayOfWeek == 0) ? 8 : (int)ngayHienTai.DayOfWeek + 1;
            bool isToday = (ngayHienTai.Date == DateTime.Now.Date);

            var lichTrongNgay = lichDay.Where(x => x.Thu == thu).ToList();
            var loiNhacTrongNgay = loiNhacs.Where(x => x.HanChot.HasValue && x.HanChot.Value.Date == ngayHienTai.Date).ToList();
            var canhBaoTrongNgay = canhBaos.Where(x => x.HanChot.HasValue && x.HanChot.Value.Date == ngayHienTai.Date).ToList();

            <div class="day-cell @(isToday ? "today" : "")">
                <div><span class="day-num">@d</span></div>

                @foreach (var l in lichTrongNgay)
                {
                    // Lấy giờ học từ CSDL
                    string gioHoc = (l.GioBatDau.HasValue && l.GioKetThuc.HasValue)
                    ? $"{l.GioBatDau.Value.ToString(@"hh\:mm")} - {l.GioKetThuc.Value.ToString(@"hh\:mm")}"
                    : l.TenCa;

                    //Lấy tên lớp
                    string tenLopHienThi = l.MaLopNavigation != null ? l.MaLopNavigation.TenLop : l.MaLop;

                    <div class="event-badge badge-schedule" title="@gioHoc | @tenLopHienThi">
                        <span class="event-title"><i class="fas fa-clock me-1"></i> @gioHoc</span>
                        <span class="event-desc fw-bold">@tenLopHienThi</span>
                    </div>
                }

                @foreach (var ln in loiNhacTrongNgay)
                {
                    <div class="event-badge badge-reminder" title="@ln.TieuDe">
                        <span class="event-title"><i class="fas fa-tasks me-1"></i> @ln.TieuDe</span>
                        <span class="event-desc">@ln.NoiDung</span>
                    </div>
                }

                @foreach (var cb in canhBaoTrongNgay)
                {
                    <div class="event-badge badge-alert" title="@cb.TieuDe">
                        <span class="event-title"><i class="fas fa-exclamation-circle me-1"></i> @cb.TieuDe</span>
                        <span class="event-desc">@cb.NoiDungCb</span>
                    </div>
                }
            </div>
        }
    </div>
</div>


