@model IEnumerable<TTNguVan.Models.LopHoc>
@{
    ViewData["Title"] = "Quản lý lớp học";
    Layout = "~/Views/Shared/_ManagerLayout.cshtml";

    var dsPT = (List<TTNguVan.Models.CtPhuTrach>)ViewBag.AllPhuTrach;
    var dsUser = (List<TTNguVan.Models.TaiKhoan>)ViewBag.AllUsers;
}

@section Styles {
    <style>
        .icon-tron {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .card-bento-table {
            background: #fff;
            border-radius: 16px;
            border: 1px solid var(--border-color);
            overflow: hidden; 
            height: calc(100vh - 250px); 
            display: flex;
            flex-direction: column;
        }

        .table-scroll-container {
            flex: 1;
            overflow-y: auto;
        }

        .table-custom thead th {
            position: sticky;
            top: 0;
            background-color: #f8fafc; 
            z-index: 10;
            box-shadow: 0 1px 0 var(--border-color); 
            padding: 16px;
            color: #64748b;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
        }

        .table-custom tbody td {
            padding: 16px;
            vertical-align: middle;
            border-bottom: 1px solid #f1f5f9;
        }

        .table-custom tbody tr:hover {
            background-color: #f8fafc;
            transition: 0.2s;
        }

        .action-icon {
            cursor: pointer; margin: 0 4px; font-size: 16px; transition: all 0.2s ease-in-out;
            display: inline-flex; width: 32px; height: 32px; align-items: center; justify-content: center;
            border-radius: 8px; background: transparent; text-decoration: none; border: none;
        }
        .action-icon.edit { color: #64748b; }
        .action-icon.edit:hover { background-color: #64748b; color: white; box-shadow: 0 2px 5px rgba(100, 116, 139, 0.4); }
        .action-icon.delete { color: #ef4444; }
        .action-icon.delete:hover { background-color: #ef4444; color: white; box-shadow: 0 2px 5px rgba(239, 68, 68, 0.4); }

        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(15, 23, 42, 0.6);
            z-index: 1000;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(4px);
        }

        .modal-content {
            background: white;
            width: 90%;
            max-width: 800px;
            padding: 40px;
            border-radius: 24px;
            max-height: 90vh;
            overflow-y: auto;
        }

        .input-group {
            margin-bottom: 16px;
            display: block;
        }

        .input-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            font-size: 13px;
            color: var(--text-muted);
        }

        .input-group input, .input-group textarea, .input-group select {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid var(--border-color);
            border-radius: 12px;
            outline: none;
            transition: 0.2s;
            font-size: 14px;
        }

        .input-group input:focus, .input-group textarea:focus, .input-group select:focus {
            border-color: var(--primary);
        }

        .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); display: none; align-items: center; justify-content: center; z-index: 9999; backdrop-filter: blur(2px); }
        .modal-delete { background: #fff; width: 400px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); padding: 30px 24px; position: relative; text-align: center; animation: slideDown 0.3s ease-out; }
        @@keyframes slideDown { from { transform: translateY(-20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        .icon-warning { font-size: 56px; color: #ef4444; margin-bottom: 15px; }
        .delete-title { font-size: 22px; font-weight: 700; color: var(--text-main); margin-bottom: 10px; }
        .delete-desc { font-size: 15px; color: var(--text-muted); margin-bottom: 25px; line-height: 1.5; }
        .delete-desc strong { color: #ef4444; font-weight: 700; }
        .delete-actions { display: flex; gap: 12px; }
        .btn-cancel { flex: 1; padding: 12px; border-radius: 10px; border: 1px solid var(--border-color); background: #fff; color: var(--text-main); font-weight: 600; cursor: pointer; transition: 0.2s; font-size: 14px; }
        .btn-cancel:hover { background: #f8fafc; }
        .btn-danger { flex: 1; padding: 12px; border-radius: 10px; border: none; background: #ef4444; color: white; font-weight: 600; cursor: pointer; transition: 0.2s; font-size: 14px; }
        .btn-danger:hover { background: #dc2626; box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3); }
        
        .btn-primary-custom { background: var(--primary); color: white; border: none; padding: 12px 24px; border-radius: 12px; font-weight: 600; transition: 0.2s; }
        .btn-primary-custom:hover { background: var(--primary-hover); }

        #toast {
            position: fixed;
            top: 30px;
            right: 30px;
            background: var(--primary); 
            color: white;
            padding: 16px 24px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            gap: 12px;
            z-index: 9999;
            transform: translateX(150%);
            transition: all 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.35);
            font-weight: 500;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

            #toast.show {
                transform: translateX(0);
            }

            #toast.toast-error {
                background: #ef4444 !important;
            }
    </style>
}
<div id="toast">
    <i class="fas fa-check-circle"></i>
    <span id="toast-message">Thông báo!</span>
</div>
<div class="page-title-group mb-4 d-flex justify-content-between align-items-center">
    <div>
        <h2 style="font-size: 26px; font-weight: 700; color: var(--text-main); margin-bottom: 6px;">Quản lý lớp học</h2>
        <p style="color: var(--text-muted); font-size: 15px; margin: 0;">Tạo và phân công nhân sự cho các lớp học</p>
    </div>
    <button class="btn-primary-custom" onclick="openAddModal()">
        <i class="fas fa-plus me-2"></i> Thêm lớp học
    </button>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card-bento d-flex align-items-center gap-3 p-3 bg-white" style="border-radius: 16px; border: 1px solid var(--border-color);">
            <div class="icon-tron" style="background:#eaf4f1; color:var(--primary);"><i class="fas fa-school"></i></div>
            <div>
                <div style="color: var(--text-muted); font-size: 13px; font-weight: 600; margin-bottom: 4px;">TỔNG SỐ LỚP</div>
                <div style="font-size: 24px; font-weight: 700; color: var(--text-main); line-height: 1;">@ViewBag.TongSoLop</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card-bento d-flex align-items-center gap-3 p-3 bg-white" style="border-radius: 16px; border: 1px solid var(--border-color);">
            <div class="icon-tron" style="background:#e0f2fe; color:#0284c7;"><i class="fas fa-user-tie"></i></div>
            <div>
                <div style="color: var(--text-muted); font-size: 13px; font-weight: 600; margin-bottom: 4px;">GIÁO VIÊN</div>
                <div style="font-size: 24px; font-weight: 700; color: var(--text-main); line-height: 1;">@ViewBag.SoGiaoVien</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card-bento d-flex align-items-center gap-3 p-3 bg-white" style="border-radius: 16px; border: 1px solid var(--border-color);">
            <div class="icon-tron" style="background:#f3e8ff; color:#9333ea;"><i class="fas fa-user-graduate"></i></div>
            <div>
                <div style="color: var(--text-muted); font-size: 13px; font-weight: 600; margin-bottom: 4px;">TRỢ GIẢNG</div>
                <div style="font-size: 24px; font-weight: 700; color: var(--text-main); line-height: 1;">@ViewBag.SoTroGiang</div>
            </div>
        </div>
    </div>
</div>

<div class="card-bento-table">
    <div class="table-scroll-container">
        <table class="table-custom w-100" style="border-collapse: collapse;">
            <thead>
                <tr>
                    <th class="ps-4" style="width: 10%;">Mã lớp</th>
                    <th style="width: 20%;">Tên lớp học</th>
                    <th class="text-center" style="width: 12%;">Sĩ số</th>
                    <th style="width: 25%;">Nhân sự phụ trách</th>
                    <th style="width: 23%;">Mô tả chi tiết</th>
                    <th class="text-end pe-4" style="width: 10%;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var phuTrachLop = dsPT.Where(p => p.MaLop == item.MaLop).ToList();
                    var gv = phuTrachLop.FirstOrDefault(p => p.VaiTro == "Giáo viên");
                    var TG = phuTrachLop.FirstOrDefault(p => p.VaiTro == "Trợ giảng");

                    var tenGV = dsUser.FirstOrDefault(u => u.MaTk == gv?.MaTk)?.HoTen ?? "Chưa phân công";
                    var tenTG = dsUser.FirstOrDefault(u => u.MaTk == TG?.MaTk)?.HoTen ?? "Chưa phân công";

                    int soLuongHV = item.HocViens != null ? item.HocViens.Count() : 0;

                    <tr>
                        <td class="ps-4" style="font-weight: 600; color: var(--text-muted); font-family: monospace;">@item.MaLop</td>
                        <td style="font-weight: 600; color: var(--text-main);">@item.TenLop</td>
                        
                        <td class="text-center">
                            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-2 py-1" style="border-radius: 6px; font-size: 13px;">  @soLuongHV Học viên </span>
                        </td>

                        <td>
                            <div style="font-size: 13px; line-height: 1.6;">
                                <div><b style="color: var(--text-muted);">GV:</b> @tenGV</div>
                                <div><b style="color: var(--text-muted);">TG:</b> @tenTG</div>
                            </div>
                        </td>
                        <td style="color: var(--text-muted); font-size: 13px; max-width: 250px;">@item.MoTa</td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-1">
                                <button type="button" class="action-icon edit" title="Sửa"
                                        onclick="openEditModal('@item.MaLop', '@item.TenLop', '@item.MoTa', '@gv?.MaTk', '@TG?.MaTk', '@(gv != null ? gv.NgayBatDauPt.ToString("yyyy-MM-dd") : "")', '@(gv != null ? gv.NgayKetThucPt.ToString("yyyy-MM-dd") : "")')">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button type="button" class="action-icon delete" title="Xóa" onclick="openDeleteModal('@item.MaLop', '@Html.Raw(item.TenLop.Replace("'", "\\'"))')">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal" id="modalLop">
    <div class="modal-content border-0">
        <h3 id="modalTitle" style="margin-bottom:25px; color: var(--text-main); font-weight: 700;">Thêm lớp học mới</h3>
        <form id="formLop" action="/QuanLy/ThemLop" method="post">
            <input type="hidden" name="MaLop" id="inputMaLop" />

            <div class="input-group">
                <label>Tên lớp học</label>
                <input type="text" name="TenLop" id="inputTenLop" placeholder="Ví dụ: Lớp Ngữ Văn 10A" required />
            </div>

            <div class="row">
                <div class="col-md-6 input-group">
                    <label>Giáo viên dạy chính</label>
                    <select name="MaGV" id="inputMaGv">
                        <option value="">-- Chọn Giáo viên --</option>
                        @foreach (var giaov in (SelectList)ViewBag.DsGiaoVien)
                        {
                            <option value="@giaov.Value">@giaov.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-6 input-group">
                    <label>Trợ giảng hỗ trợ</label>
                    <select name="MaTG" id="inputMaTG">
                        <option value="">-- Chọn Trợ giảng --</option>
                        @foreach (var troG in (SelectList)ViewBag.DsTroGiang)
                        {
                            <option value="@troG.Value">@troG.Text</option>
                        }
                    </select>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 input-group">
                    <label>Ngày bắt đầu</label>
                    <input type="date" name="NgayBD" id="inputNgayBD" required />
                </div>
                <div class="col-md-6 input-group">
                    <label>Ngày kết thúc</label>
                    <input type="date" name="NgayKT" id="inputNgayKT" required />
                </div>
            </div>

            <div class="input-group mb-4">
                <label>Mô tả / Ghi chú</label>
                <textarea name="MoTa" id="inputMoTa" rows="3" placeholder="Nhập lịch học, thời gian..."></textarea>
            </div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn-primary-custom w-100 justify-content-center">Lưu thông tin</button>
                <button type="button" onclick="toggleModal(false)" class="btn w-100" style="background: #f1f5f9; color: var(--text-muted); font-weight: 600;">Hủy bỏ</button>
            </div>
        </form>
    </div>
</div>

<div id="deleteModal" class="modal-overlay">
    <div class="modal-delete">
        <i class="fas fa-exclamation-triangle icon-warning"></i>
        <h3 class="delete-title">Xác nhận xóa?</h3>
        <p class="delete-desc">Bạn có chắc chắn muốn xóa lớp <br/><strong id="delete-name-display"></strong> không?</p>
        
        <form action="/QuanLy/XoaLop" method="post" class="delete-actions m-0">
            <input type="hidden" id="delete-id" name="id" />
            <button type="button" class="btn-cancel" onclick="closeDeleteModal()">Hủy bỏ</button>
            <button type="submit" class="btn-danger">Xóa ngay</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Xử lý modal thêm, sửa lớp
        function toggleModal(show) {
            document.getElementById('modalLop').style.display = show ? 'flex' : 'none';
        }

        function openAddModal() {
            document.getElementById('modalTitle').innerText = "Thêm lớp học mới";
            document.getElementById('formLop').action = "/QuanLy/ThemLop";
            document.getElementById('formLop').reset();
            document.getElementById('inputMaLop').value = ""; // Đảm bảo rỗng khi thêm mới
            toggleModal(true);
        }

        function openEditModal(ma, ten, mota, magv, maTG, bd, kt) {
            document.getElementById('modalTitle').innerText = "Chỉnh sửa lớp học";
            document.getElementById('formLop').action = "/QuanLy/SuaLop";

            document.getElementById('inputMaLop').value = ma;
            document.getElementById('inputTenLop').value = ten;
            document.getElementById('inputMoTa').value = mota;
            document.getElementById('inputMaGv').value = magv || "";
            document.getElementById('inputMaTG').value = maTG || "";
            document.getElementById('inputNgayBD').value = bd || "";
            document.getElementById('inputNgayKT').value = kt || "";

            toggleModal(true);
        }

        // Xử lý modal xóa
        function openDeleteModal(id, name) {
            document.getElementById('delete-id').value = id;
            document.getElementById('delete-name-display').innerText = name; 
            document.getElementById('deleteModal').style.display = 'flex';
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').style.display = 'none';
        }

        // Đóng các modal khi click ra ngoài vùng mờ
        window.onclick = function(event) {
            let modalLop = document.getElementById('modalLop');
            let deleteModal = document.getElementById('deleteModal');
            
            if (event.target == modalLop) {
                toggleModal(false);
            }
            if (event.target == deleteModal) {
                closeDeleteModal();
            }
        }

        // Toast thông báo
        function showToast(message, isError = false) {
            const toast = document.getElementById('toast');
            const icon = toast.querySelector('i');

            document.getElementById('toast-message').innerText = message;

            // Đổi màu và icon tùy theo loại thông báo
            if(isError) {
                toast.classList.add('toast-error');
                icon.className = 'fas fa-exclamation-triangle';
            } else {
                toast.classList.remove('toast-error');
                icon.className = 'fas fa-check-circle';
            }

            // Hiển thị
            toast.classList.add('show');

            // Tự động ẩn sau 3 giây
            setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // Hứng dữ liệu từ Controller
        window.onload = function() {
            var successMsg = "@Html.Raw(TempData["SuccessMessage"])";
            var errorMsg = "@Html.Raw(TempData["Error"])";

            if (successMsg && successMsg !== "") {
                showToast(successMsg, false);
            }

            if (errorMsg && errorMsg !== "") {
                showToast(errorMsg, true);
            }
        };
    </script>
}