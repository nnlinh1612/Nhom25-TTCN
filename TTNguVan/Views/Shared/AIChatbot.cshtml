@* Views/Shared/_AIChatbot.cshtml *@

<style>
    #ai-chatbot-button {
        position: fixed;
        right: 28px;
        bottom: 28px;
        width: 62px;
        height: 62px;
        border-radius: 50%;
        background: linear-gradient(135deg, #4DB6A3, #2F9C8A);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-weight: 800;
        font-size: 18px;
        z-index: 99999;
        box-shadow: 0 12px 28px rgba(47, 156, 138, 0.38);
        border: 4px solid #ffffff;
    }

    #ai-chatbot-box {
        position: fixed;
        right: 28px;
        bottom: 102px;
        width: 390px;
        max-width: calc(100vw - 32px);
        height: 570px;
        max-height: calc(100vh - 120px);
        background: #ffffff;
        border-radius: 22px;
        box-shadow: 0 18px 45px rgba(15, 23, 42, 0.22);
        overflow: hidden;
        display: none;
        z-index: 99999;
        border: 1px solid #D7EEE9;
    }

    .ai-chatbot-header {
        height: 72px;
        padding: 14px 18px;
        background: linear-gradient(135deg, #4DB6A3, #2F9C8A);
        color: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .ai-chatbot-header strong {
            font-size: 18px;
            font-weight: 800;
        }

        .ai-chatbot-header button {
            width: 34px;
            height: 34px;
            border: none;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.18);
            color: white;
            font-size: 24px;
            line-height: 1;
            cursor: pointer;
        }

    .ai-chatbot-subtitle {
        font-size: 12px;
        opacity: 0.95;
        margin-top: 3px;
    }

    .ai-chatbot-body {
        padding: 14px;
        height: calc(100% - 72px);
        display: flex;
        flex-direction: column;
        gap: 10px;
        background: #F8FCFB;
    }

        .ai-chatbot-body label {
            font-size: 13px;
            font-weight: 700;
            color: #334155;
            margin-bottom: 5px;
            display: block;
        }

    .ai-chatbot-select {
        width: 100%;
        height: 40px;
        border: 1px solid #CDE8E2;
        border-radius: 12px;
        padding: 0 12px;
        color: #1f2937;
        background: white;
        outline: none;
    }

        .ai-chatbot-select:focus,
        .ai-chatbot-input:focus {
            border-color: #4DB6A3;
            box-shadow: 0 0 0 3px rgba(77, 182, 163, 0.16);
        }

    .ai-chatbot-messages {
        flex: 1;
        overflow-y: auto;
        border: 1px solid #DCEFEB;
        border-radius: 16px;
        padding: 12px;
        background: #ffffff;
    }

    .ai-message {
        padding: 10px 12px;
        border-radius: 14px;
        margin-bottom: 10px;
        font-size: 14px;
        line-height: 1.5;
        white-space: pre-wrap;
        max-width: 86%;
    }

    .ai-message-user {
        background: #DDF4EF;
        color: #134E44;
        margin-left: auto;
        border-bottom-right-radius: 5px;
    }

    .ai-message-bot {
        background: #F7FAF9;
        color: #1f2937;
        border: 1px solid #E1F0EC;
        margin-right: auto;
        border-bottom-left-radius: 5px;
    }

    .ai-chatbot-input {
        resize: none;
        border: 1px solid #CDE8E2;
        border-radius: 16px;
        padding: 12px;
        font-size: 14px;
        outline: none;
        background: white;
    }

    .ai-chatbot-send {
        height: 42px;
        border: none;
        border-radius: 14px;
        background: linear-gradient(135deg, #4DB6A3, #2F9C8A);
        color: white;
        font-weight: 800;
        cursor: pointer;
        box-shadow: 0 8px 18px rgba(47, 156, 138, 0.24);
    }

        .ai-chatbot-send:hover {
            filter: brightness(0.98);
            transform: translateY(-1px);
        }

        .ai-chatbot-send:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }

    @@media (max-width: 576px) {
        #ai-chatbot-box {
            right: 12px;
            left: 12px;
            bottom: 90px;
            width: auto;
            height: 540px;
        }

        #ai-chatbot-button {
            right: 18px;
            bottom: 18px;
        }
    }
</style>

<div id="ai-chatbot-button" onclick="toggleAiChatbot()">
    AI
</div>

<div id="ai-chatbot-box">
    <div class="ai-chatbot-header">
        <div>
            <strong>Trợ lý AI</strong>
            <div class="ai-chatbot-subtitle">Tư vấn · Chấm bài · Tóm tắt</div>
        </div>
        <button type="button" onclick="toggleAiChatbot()">×</button>
    </div>

    <div class="ai-chatbot-body">
        <div>
            <label style="font-size: 13px; font-weight: 600;">Chế độ</label>
            <select id="aiMode" class="ai-chatbot-select">
                <option value="reply">Hỗ trợ trả lời tin nhắn</option>
                <option value="grade">Chấm bài / góp ý bài văn</option>
                <option value="summary">Tóm tắt lịch sử tư vấn</option>
                <option value="general">Hỏi AI chung</option>
            </select>
        </div>

        <input type="hidden" id="aiMaKhachHang" value="@ViewBag.MaKhachHang" />

        <div id="aiMessages" class="ai-chatbot-messages">
            <div class="ai-message ai-message-bot">
                Xin chào, mình có thể hỗ trợ tư vấn, chấm bài hoặc tóm tắt lịch sử khách hàng.
            </div>
        </div>

        <textarea id="aiInput"
                  class="ai-chatbot-input"
                  rows="4"
                  placeholder="Nhập nội dung cần AI hỗ trợ..."></textarea>

        <button type="button" class="ai-chatbot-send" onclick="sendAiMessage()">
            Gửi
        </button>
    </div>
</div>

<script>
    function toggleAiChatbot() {
        const box = document.getElementById("ai-chatbot-box");

        if (!box) return;

        box.style.display = box.style.display === "block" ? "none" : "block";
    }

    function appendAiMessage(text, type) {
        const messages = document.getElementById("aiMessages");

        if (!messages) return;

        const div = document.createElement("div");

        div.className = type === "user"
            ? "ai-message ai-message-user"
            : "ai-message ai-message-bot";

        div.innerText = text;

        messages.appendChild(div);
        messages.scrollTop = messages.scrollHeight;
    }

    async function sendAiMessage() {
        const input = document.getElementById("aiInput");
        const mode = document.getElementById("aiMode");
        const maKhachHang = document.getElementById("aiMaKhachHang");
        const sendButton = document.querySelector(".ai-chatbot-send");

        if (!input || !mode) return;

        const message = input.value.trim();

        if (!message) {
            appendAiMessage("Vui lòng nhập nội dung cần hỗ trợ.", "bot");
            return;
        }

        appendAiMessage(message, "user");
        input.value = "";

        appendAiMessage("Đang xử lý...", "bot");

        if (sendButton) {
            sendButton.disabled = true;
        }

        const formData = new FormData();
        formData.append("mode", mode.value);
        formData.append("message", message);

        if (maKhachHang && maKhachHang.value) {
            formData.append("maKhachHang", maKhachHang.value);
        }

        try {
            const response = await fetch("/Ai/Chat", {
                method: "POST",
                body: formData
            });

            const data = await response.json();

            const messages = document.getElementById("aiMessages");
            if (messages && messages.lastElementChild) {
                messages.removeChild(messages.lastElementChild);
            }

            if (data.success) {
                appendAiMessage(data.reply, "bot");
            } else {
                appendAiMessage(data.reply || "Có lỗi xảy ra.", "bot");
            }
        } catch (error) {
            const messages = document.getElementById("aiMessages");
            if (messages && messages.lastElementChild) {
                messages.removeChild(messages.lastElementChild);
            }

            appendAiMessage("Không thể kết nối tới AI. Vui lòng thử lại.", "bot");
        }

        if (sendButton) {
            sendButton.disabled = false;
        }
    }

    document.addEventListener("keydown", function (event) {
        const box = document.getElementById("ai-chatbot-box");
        const input = document.getElementById("aiInput");

        if (!box || !input) return;

        if (box.style.display === "block" && document.activeElement === input) {
            if (event.key === "Enter" && event.ctrlKey) {
                sendAiMessage();
            }
        }
    });
</script>