@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor Accessor
@{
    var hoTen = Accessor.HttpContext?.Session.GetString("HoTen") ?? "Nhân viên Sale";
    var Email = Accessor.HttpContext?.Session.GetString("Email") ?? "admin@gmail.com";
    var avatarChar = !string.IsNullOrEmpty(hoTen) ? hoTen.Substring(0, 1).ToUpper() : "S";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ngữ Văn Minh Anh</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap">

    <style>
        :root {
            --primary: #52ab98;
            --primary-hover: #428e7d;
            --bg-body: #f8fafc;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --border-color: #e2e8f0;
            --sidebar-width: 280px; 
        }

        * {
            box-sizing: border-box !important;
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 0;
        }

        body {
            display: flex !important;
            height: 100vh !important;
            background-color: var(--bg-body) !important;
            overflow: hidden !important;
        }

        .thanh-sidebar {
            width: var(--sidebar-width) !important;
            min-width: var(--sidebar-width) !important;
            height: 100vh !important;
            background-color: #ffffff !important;
            border-right: 1px solid var(--border-color) !important;
            display: flex !important;
            flex-direction: column !important;
        }

        .logo-header {
            padding: 32px 24px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .logo-box {
            background-color: var(--primary);
            color: white;
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .logo-text {
            font-size: 20px;
            font-weight: 600;
            color: var(--text-main);
            text-decoration: none;
            letter-spacing: -0.5px;
        }

        .menu-list {
            flex: 1;
            padding: 0 16px;
        }

        .menu-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 16px;
            text-decoration: none !important;
            color: var(--text-muted);
            font-size: 15px;
            font-weight: 400;
            border-radius: 12px;
            margin-bottom: 4px;
            transition: 0.2s;
        }

            .menu-item i {
                font-size: 18px;
                width: 20px;
                text-align: center;
            }

            .menu-item.active {
                background-color: #eaf4f1;
                color: var(--primary);
                font-weight: 500;
            }

            .menu-item:hover:not(.active) {
                background-color: var(--bg-body);
                color: var(--text-main);
            }

        .sidebar-footer {
            padding: 24px;
            border-top: 1px solid var(--border-color);
            margin-top: auto;
        }

        .profile-box {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 24px;
        }

        .avatar-circle {
            width: 44px;
            height: 44px;
            background-color: var(--primary);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 18px;
        }

        .profile-name {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-main);
            display: block;
        }

        .profile-email {
            font-size: 12px;
            color: var(--text-muted);
        }

        .logout-link {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            color: var(--text-main);
            font-size: 15px;
            font-weight: 500;
        }

        .vung-chinh {
            flex: 1 !important;
            height: 100vh !important;
            overflow-y: auto !important;
            padding: 35px 40px !important;
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .page-title-group {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

            .page-title-group h2 {
                font-size: 26px;
                font-weight: 700;
                color: var(--text-main);
                margin-bottom: 5px;
            }

            .page-title-group p {
                color: var(--text-muted);
                font-size: 14px;
                margin: 0;
            }

        .btn-primary-custom {
            background: var(--primary);
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 12px;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            font-size: 14px;
            transition: 0.3s;
        }

            .btn-primary-custom:hover {
                background: var(--primary-hover);
                transform: translateY(-2px);
                color: white;
            }

        .card-bento {
            background: white;
            border-radius: 20px;
            border: 1px solid var(--border-color);
            padding: 24px;
        }

        .card-bento-table {
            background: white;
            border-radius: 20px;
            border: 1px solid var(--border-color);
            overflow: hidden;
        }

        .table-custom {
            width: 100%;
            border-collapse: collapse;
            margin: 0;
        }

            .table-custom thead th {
                background: var(--bg-body);
                color: var(--text-muted);
                font-size: 12px;
                font-weight: 600;
                text-transform: uppercase;
                padding: 18px 24px;
                border-bottom: 1px solid var(--border-color);
                text-align: left;
            }

            .table-custom tbody td {
                padding: 18px 24px;
                border-bottom: 1px solid var(--border-color);
                font-size: 14px;
                color: var(--text-main);
                vertical-align: middle;
            }

            .table-custom tbody tr:last-child td {
                border-bottom: none;
            }

            .table-custom tbody tr:hover {
                background-color: var(--bg-body);
                transition: 0.2s;
            }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>

    <div class="thanh-sidebar">
        <div class="logo-header">
            <div class="logo-box"><i class="fas fa-graduation-cap"></i></div>
            <span class="logo-text">Ngữ Văn Minh Anh</span>
        </div>

        <div class="menu-list">
            <a href="/QuanLy/Dashboard" class="menu-item @(Context.Request.Path.Value.Contains("Dashboard") ? "active" : "")">
                <i class="fas fa-th-large"></i><span>Dashboard</span>
            </a>
            <a href="/QuanLy/QuanLyLop" class="menu-item @(Context.Request.Path.Value.Contains("QuanLyLop") ? "active" : "")">
                <i class="fas fa-school"></i><span>Quản lý lớp</span>
            </a>
            <a href="/QuanLy/QuanLyBaiTest" class="menu-item @(Context.Request.Path.Value.Contains("QuanLyBaiTest") ? "active" : "")">
                <i class="fas fa-clipboard-list"></i><span>Quản lý bài test</span>
            </a>
        </div>

        <div class="sidebar-footer">
            <div class="profile-box">
                <div class="avatar-circle">@avatarChar</div>
                <div class="profile-info">
                    <span class="profile-name">@hoTen</span>
                    <span class="profile-email">@Email</span>
                </div>
            </div>
            <a href="/TaiKhoan/DangXuat" class="logout-link">
                <i class="fas fa-sign-out-alt"></i><span>Đăng xuất</span>
            </a>
        </div>
    </div>

    <div class="vung-chinh">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
    @await Html.PartialAsync("AIChatbot")
</body>
</html>