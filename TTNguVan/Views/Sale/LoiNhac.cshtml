@model IEnumerable<TTNguVan.Models.ThongBaoViewModel>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Lời nhắc công việc";
    Layout = "~/Views/Shared/_LayoutSale.cshtml";
}

@section Styles {
    <style>
        .main-container-bento {
            margin-left: 280px;
            padding: 30px;
            background-color: #f4f6f9;
            min-height: 100vh;
            width: calc(100% - 280px);
            transition: all 0.3s;
        }

        @@media (max-width: 992px) {
            .main-container-bento {
                margin-left: 0;
                width: 100%;
            }
        }

        .page-title {
            font-size: 24px;
            font-weight: 700;
            color: #1e293b;
        }

        /* Thẻ thống kê */
        .stat-card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            padding: 20px;
            display: flex;
            align-items: center;
            background: #fff;
            height: 100%;
        }

            .stat-card:hover {
                transform: translateY(-5px);
            }

        .stat-icon {
            width: 54px;
            height: 54px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            margin-right: 15px;
        }

        .stat-info h3 {
            margin: 0;
            font-size: 26px;
            font-weight: 700;
            color: #1e293b;
        }

        .stat-info p {
            margin: 0;
            color: #64748b;
            font-size: 14px;
            font-weight: 500;
        }

        /* Màu sắc icon */
        .icon-blue {
            background-color: #e0f2fe;
            color: #0284c7;
        }

        .icon-green {
            background-color: #dcfce7;
            color: #15803d;
        }

        .icon-orange {
            background-color: #ffedd5;
            color: #c2410c;
        }

        /* Bảng dữ liệu */
        .content-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
            padding: 25px;
            margin-top: 20px;
            border: 1px solid #edf2f7;
            width: 100%;
        }

        .table th {
            background-color: #f8fafc;
            border-bottom: 2px solid #f1f5f9;
            font-weight: 600;
            color: #475569;
            font-size: 13px;
            text-transform: uppercase;
            padding: 15px;
        }

        .table td {
            font-size: 14px;
            vertical-align: middle;
            color: #334155;
            padding: 15px;
        }

        .btn-add-new {
            background-color: #3ba786;
            color: #fff;
            border-radius: 10px;
            padding: 10px 22px;
            font-weight: 600;
            border: none;
            transition: 0.3s;
        }

            .btn-add-new:hover {
                background-color: #2f8f71;
                box-shadow: 0 4px 12px rgba(59, 167, 134, 0.3);
                color: #fff;
            }

        /* Custom Badge Styles */
        .badge {
            padding: 6px 12px;
            border-radius: 6px;
            font-weight: 600;
            font-size: 12px;
        }

        /* --- CSS CHO MODAL XÓA (MOCKUP XỊN) --- */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.4);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            backdrop-filter: blur(2px);
        }

        .modal-delete {
            background: #fff;
            width: 400px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            padding: 30px 24px;
            position: relative;
            text-align: center;
            animation: slideDown 0.3s ease-out;
        }

        @@keyframes slideDown {
            from {
                transform: translateY(-20px);
                opacity: 0;
            }

            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .icon-warning {
            font-size: 56px;
            color: #ef4444;
            margin-bottom: 15px;
        }

        .delete-title {
            font-size: 22px;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 10px;
        }

        .delete-desc {
            font-size: 15px;
            color: #64748b;
            margin-bottom: 25px;
            line-height: 1.5;
        }

            .delete-desc strong {
                color: #ef4444;
                font-weight: 700;
            }

        .delete-actions {
            display: flex;
            gap: 12px;
        }

        .btn-cancel {
            flex: 1;
            padding: 12px;
            border-radius: 10px;
            border: 1px solid #e2e8f0;
            background: #fff;
            color: #1e293b;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            font-size: 14px;
        }

            .btn-cancel:hover {
                background: #f8fafc;
            }

        .btn-danger {
            flex: 1;
            padding: 12px;
            border-radius: 10px;
            border: none;
            background: #ef4444;
            color: white;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            font-size: 14px;
        }

            .btn-danger:hover {
                background: #dc2626;
                box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
            }

        .tab-container {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            background: #f1f5f9;
            padding: 5px;
            border-radius: 12px;
            width: fit-content;
        }

        .tab-btn {
            padding: 10px 24px;
            border-radius: 10px;
            border: none;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            transition: 0.3s;
            text-decoration: none !important;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            /* Tab chưa chọn */
            .tab-btn.inactive {
                background: transparent;
                color: #64748b;
            }

                .tab-btn.inactive:hover {
                    background: #e2e8f0;
                }

            /* Tab đang chọn - Màu Lời nhắc (Xanh) */
            .tab-btn.active-blue {
                background: #ffffff;
                color: #0ea5e9;
                box-shadow: 0 4px 10px rgba(0,0,0,0.05);
            }

            /* Tab đang chọn - Màu Quá hạn (Đỏ) */
            .tab-btn.active-red {
                background: #ef4444;
                color: #ffffff;
                box-shadow: 0 4px 12px rgba(239, 68, 68, 0.2);
            }

        .badge-count {
            font-size: 11px;
            padding: 2px 8px;
            border-radius: 20px;
            background: rgba(0,0,0,0.1);
        }

        .tab-wrapper {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            background: #e2e8f0;
            padding: 6px;
            border-radius: 14px;
            width: fit-content;
        }

        .tab-item {
            padding: 10px 24px;
            border-radius: 10px;
            font-weight: 700;
            font-size: 14px;
            text-decoration: none !important;
            transition: 0.3s;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .tab-item.inactive {
                color: #64748b;
            }

                .tab-item.inactive:hover {
                    background: rgba(255,255,255,0.5);
                }

            .tab-item.active-blue {
                background: #fff;
                color: #0ea5e9;
                box-shadow: 0 4px 10px rgba(0,0,0,0.05);
            }

            .tab-item.active-red {
                background: #ef4444;
                color: #fff;
                box-shadow: 0 4px 12px rgba(239, 68, 68, 0.2);
            }

        .badge-num {
            font-size: 11px;
            padding: 2px 8px;
            border-radius: 20px;
            background: rgba(0,0,0,0.1);
        }
    </style>
}

<div class="page-title-group mb-4 d-flex justify-content-between align-items-center">
    <div>
        <h2 style="font-size: 26px; font-weight: 700; color: var(--text-main); margin-bottom: 6px;">Lời nhắc công việc</h2>
        <p style="color: var(--text-muted); font-size: 15px; margin: 0;">Quản lý và theo dõi tiến độ các nhiệm vụ cá nhân</p>
    </div>
    <button class="btn-add-new" data-bs-toggle="modal" data-bs-target="#modalThemLoiNhac">
        <i class="fas fa-plus me-1"></i> Thêm lời nhắc
    </button>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-icon icon-blue"><i class="fas fa-list-ul"></i></div>
            <div class="stat-info">
                <h3>@ViewBag.TongCongViec</h3>
                <p>Tổng lời nhắc</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-icon icon-green"><i class="fas fa-check-circle"></i></div>
            <div class="stat-info">
                <h3>@ViewBag.DaHoanThanh</h3>
                <p>Đã hoàn thành</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-icon icon-orange"><i class="fas fa-history"></i></div>
            <div class="stat-info">
                <h3>@ViewBag.ChuaHoanThanh</h3>
                <p>Chưa hoàn thành</p>
            </div>
        </div>
    </div>
</div>

<div class="content-card">
    <div class="tab-container-bento">
        <div class="tab-wrapper">
            <a href="/Sale/LoiNhac?loai=binhthuong"
               class="tab-item @(ViewBag.TabActive == "binhthuong" ? "active-blue" : "inactive")">
                <i class="far fa-calendar-check"></i> Lời nhắc
                <span class="badge-num">@ViewBag.CountBinhThuong</span>
            </a>
            <a href="/Sale/LoiNhac?loai=quahan"
               class="tab-item @(ViewBag.TabActive == "quahan" ? "active-red" : "inactive")">
                <i class="fas fa-exclamation-circle"></i> Quá hạn
                <span class="badge-num">@ViewBag.CountQuaHan</span>
            </a>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th width="5%" class="text-center">STT</th>
                    <th width="20%">Tiêu đề</th>
                    <th width="25%">Nội dung</th>
                    <th width="15%">Hạn chót</th>
                    <th width="10%" class="text-center">Mức độ</th>
                    <th width="12%" class="text-center">Trạng thái</th>
                    <th width="13%" class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    int stt = 1;
                    foreach (var item in Model)
                    {
                        bool isDone = item.TrangThai;
                        string badgeClass = "bg-secondary";
                        string label = item.MucDo;

                        if (!isDone && item.HanChot.HasValue)
                        {
                            var daysDifference = (item.HanChot.Value.Date - DateTime.Now.Date).TotalDays;
                            if (daysDifference >= 0 && daysDifference <= 2)
                            {
                                badgeClass = "bg-danger";
                                label = "Gấp";
                            }
                            else if (item.MucDo == "Quan trọng") badgeClass = "bg-warning text-dark";
                            else if (item.MucDo == "Bình thường") badgeClass = "bg-info text-dark";
                        }

                        <tr>
                            <td class="text-center fw-bold text-muted">@stt</td>

                            <td class="@(isDone ? "text-decoration-line-through text-muted" : "fw-bold text-dark")">@item.TieuDe</td>

                            <td class="@(isDone ? "text-muted" : "text-secondary")" style="white-space: normal; min-width: 200px;">@item.NoiDung</td>

                            <td class="text-muted">@item.HanChot?.ToString("dd/MM/yyyy HH:mm")</td>

                            <td class="text-center">
                                @if (isDone)
                                {
                                    <span class="badge bg-light text-muted border">@item.MucDo</span>
                                }
                                else
                                {
                                    <span class="badge @badgeClass">@label</span>
                                }
                            </td>

                            <td class="text-center">
                                @if (isDone)
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success">Đã xong</span>
                                }
                                else
                                {
                                    if (item.HanChot < DateTime.Now)
                                    {
                                        <span class="badge bg-danger">ĐÃ QUÁ HẠN</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning">Chưa xong</span>
                                    }
                                }
                            </td>

                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    @if (!isDone)
                                    {
                                        <form asp-area="Sale" asp-controller="Sale" asp-action="DanhDauXong" method="post" class="m-0">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-success border-0" title="Hoàn thành">
                                                <i class="fas fa-check-circle fs-5"></i>
                                            </button>
                                        </form>
                                    }

                                    <button type="button" class="btn btn-sm btn-outline-danger border-0" title="Xóa" onclick="openDeleteModal('@item.Id', '@Html.Raw(item.TieuDe.Replace("'", "\\'"))')">
                                        <i class="fas fa-trash-alt fs-5"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        stt++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted fst-italic">
                            <i class="fas fa-inbox fs-2 d-block mb-2" style="opacity: 0.2;"></i>
                            Chưa có lời nhắc nào trong danh sách.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="modalThemLoiNhac" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <form asp-area="Sale" asp-controller="Sale" asp-action="ThemLoiNhac" method="post">
                <div class="modal-header border-0 pb-0 px-4 pt-4">
                    <h5 class="modal-title fw-bold" style="color: #1e293b;">Thêm lời nhắc mới</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted text-uppercase" style="letter-spacing: 0.5px;">Tiêu đề công việc</label>
                        <input type="text" class="form-control" name="TieuDe" required placeholder="Nhập tiêu đề..." style="border-radius: 10px; padding: 12px; border-color: #e2e8f0;" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted text-uppercase" style="letter-spacing: 0.5px;">Nội dung chi tiết</label>
                        <textarea class="form-control" name="NoiDung" rows="3" placeholder="Nhập nội dung..." style="border-radius: 10px; padding: 12px; border-color: #e2e8f0; resize: none;"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small text-muted text-uppercase" style="letter-spacing: 0.5px;">Hạn chót</label>
                            <input type="datetime-local" class="form-control" name="HanChot" required style="border-radius: 10px; padding: 12px; border-color: #e2e8f0;" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small text-muted text-uppercase" style="letter-spacing: 0.5px;">Mức độ</label>
                            <select class="form-select" name="MucDo" required style="border-radius: 10px; padding: 12px; border-color: #e2e8f0;">
                                <option value="Quan trọng">Quan trọng</option>
                                <option value="Bình thường" selected>Bình thường</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="button" class="btn btn-light px-4 fw-bold" data-bs-dismiss="modal" style="border-radius: 10px; color: #64748b;">Hủy</button>
                    <button type="submit" class="btn px-4 fw-bold" style="background-color: #3ba786; color: white; border-radius: 10px;">Lưu dữ liệu</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div id="deleteModal" class="modal-overlay">
    <div class="modal-delete">
        <i class="fas fa-exclamation-triangle icon-warning"></i>
        <h3 class="delete-title">Xác nhận xóa?</h3>
        <p class="delete-desc">Bạn có chắc chắn muốn xóa lời nhắc <br /><strong id="delete-title-display"></strong> không?</p>

        <form asp-area="Sale" asp-controller="Sale" asp-action="XoaLoiNhac" method="post" class="delete-actions m-0">
            <input type="hidden" id="delete-id" name="id" />
            <button type="button" class="btn-cancel" onclick="closeDeleteModal()">Hủy bỏ</button>
            <button type="submit" class="btn-danger">Xóa ngay</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // --- XỬ LÝ MODAL XÓA ---
        function openDeleteModal(id, title) {
            document.getElementById('delete-id').value = id;
            document.getElementById('delete-title-display').innerText = title;
            document.getElementById('deleteModal').style.display = 'flex';
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').style.display = 'none';
        }

        // Click ra ngoài modal để đóng
        window.addEventListener('click', function(event) {
            var deleteModal = document.getElementById('deleteModal');
            if (event.target == deleteModal) {
                closeDeleteModal();
            }
        });
    </script>
}

